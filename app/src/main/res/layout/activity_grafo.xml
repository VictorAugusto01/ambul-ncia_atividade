<?xml version="1.0" encoding="utf-8"?>
<!--
  gambi em relative layout pra forçar o map fragment ficar no meio.
  se mudar pra linear caga o mapa todo, entao deixa assim msm
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:id="@+id/headerGrafo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="@color/bg_card_elevado"
        android:elevation="4dp">

        <Button
            android:id="@+id/btnVoltarGrafo"
            android:layout_width="40dp"
            android:layout_height="48dp"
            android:text="←"
            android:backgroundTint="@color/vermelho_sos"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btnMeuLocal"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:text="📍"
            android:backgroundTint="@color/verde_ok"
            android:padding="0dp"/>

        <Spinner
            android:id="@+id/spinnerBairroGrafo"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:backgroundTint="@color/white" />

        <Button
            android:id="@+id/btnBuscarGrafo"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="BUSCAR"
            android:textStyle="bold"
            android:backgroundTint="@color/vermelho_sos" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/painelInferiorGrafo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/bg_dark"
        android:elevation="4dp">

        <LinearLayout
            android:id="@+id/cardResultadoGrafo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/shape_card_arredondado"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ HOSPITAL RECOMENDADO"
                android:textColor="@color/verde_ok"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNomeResultadoGrafo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="UPA Butantã"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvVagasResultadoGrafo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    tools:text="60 vagas livres"
                    android:textColor="@color/verde_ok" />

                <TextView
                    android:id="@+id/tvDistResultadoGrafo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    tools:text="1 bairros de distância"
                    android:textColor="@color/azul_info" />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:id="@+id/logScrollGrafo"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/shape_card_arredondado"
            android:padding="12dp">

            <LinearLayout
                android:id="@+id/logContainerGrafo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/mapaGoogle"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerGrafo"
        android:layout_above="@id/painelInferiorGrafo" />

</RelativeLayout>