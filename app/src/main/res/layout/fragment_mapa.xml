<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <fragment
        android:id="@+id/mapaGoogleFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/cardResultadoFlutuante"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/shape_card_arredondado"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        tools:visibility="visible"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rota recomendada"
                android:textColor="@color/label_cinza"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/btnFecharCard"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_close"
                app:tint="@color/label_cinza" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvHospitalRecomendado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Hospital Santa Helena"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvTempoEstimado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="18 min"
                android:textColor="@color/verde_ok"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvDistanciaEstimada"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="• 7,2 km"
                android:textColor="@color/label_cinza"
                android:textSize="14sp"
                android:layout_marginEnd="16dp" />

            <TextView
                android:id="@+id/tvStatusUTI"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="UTI Disponível"
                android:textColor="@color/azul_info"
                android:background="@drawable/bg_chip_info"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:textSize="11sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnIniciarRotaGoogle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Ver detalhes / Iniciar Rota"
            android:textColor="@color/white"
            android:backgroundTint="@color/vermelho_sos"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:elevation="0dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>