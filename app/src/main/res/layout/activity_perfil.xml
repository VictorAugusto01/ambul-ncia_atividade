<?xml version="1.0" encoding="utf-8"?>
<!-- TODO: Extrair os assets visuais e chaves HEX apos aprovação do MVP -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#EF5350"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnVoltarPerfil"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="←"
                android:textColor="#FFFFFF"
                android:backgroundTint="#D32F2F"
                android:padding="0dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SOS LEITOS"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Meu perfil"
                    android:textColor="#FFCDD2"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <!-- Avatar dinamico -->
            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_chip_normal"
                android:gravity="center"
                tools:text="GA"
                android:textColor="#EF5350"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPerfilNome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Gabriel Alex"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/tvPerfilRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="👤 PACIENTE · SAMU SP"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- View do Paciente -->
        <LinearLayout
            android:id="@+id/containerFichaPaciente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEU PRONTUÁRIO"
                android:textColor="#EF5350"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_chip_normal"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvPerfilRg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="RG: 60.333.555-1"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvPerfilSangue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="Sangue: O+"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvPerfilAlergias"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="Alergias: Dipirona"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>

        <!-- View do Socorrista -->
        <LinearLayout
            android:id="@+id/containerEstatisticas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvPerfilEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_normal"
                android:padding="16dp"
                tools:text="medico@gmail.com"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvPerfilUnidade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_normal"
                android:padding="16dp"
                android:text="Base Lapa – Zona Oeste"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvPerfilAtendimentos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_normal"
                android:padding="16dp"
                android:text="127 atendimentos este mês"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/containerHospitaisProximos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOSPITAIS DISPONÍVEIS"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/listaHospitaisPerfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:gravity="bottom">
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="SAIR DA CONTA"
                android:textColor="#FFFFFF"
                android:backgroundTint="#EF5350"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>