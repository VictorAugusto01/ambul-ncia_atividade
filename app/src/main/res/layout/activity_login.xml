<?xml version="1.0" encoding="utf-8"?>
<!-- TODO: alinhar com a Emanuelly se esse padding 24dp ta bom msm -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="48dp">

        <!-- logo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginBottom="12dp">
                <View android:layout_width="44dp" android:layout_height="14dp"
                    android:layout_gravity="center_vertical" android:background="@color/vermelho_sos"/>
                <View android:layout_width="14dp" android:layout_height="44dp"
                    android:layout_gravity="center_horizontal" android:background="@color/vermelho_sos"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOS LEITOS"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acesse sua conta"
                android:textColor="@color/label_cinza"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- input email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E-MAIL"
            android:textColor="@color/label_cinza"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="16dp">

            <!-- <TextView android:text="✉" ... /> apaguei o emoji pq tava zoado -->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_email"
                app:tint="@color/label_cinza"
                android:layout_marginEnd="10dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="email@samu.sp.gov.br"
                android:textColorHint="@color/label_cinza"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:inputType="textEmailAddress"
                android:background="@null"
                android:singleLine="true"/>
        </LinearLayout>

        <!-- input senha -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SENHA"
            android:textColor="@color/label_cinza"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_lock"
                app:tint="@color/label_cinza"
                android:layout_marginEnd="10dp"/>

            <EditText
                android:id="@+id/etSenha"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="••••••••"
                android:textColorHint="@color/label_cinza"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:inputType="textPassword"
                android:background="@null"
                android:singleLine="true"/>

            <!-- icon de olhinho p/ ver senha, dps tem q fazer a logica no java -->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_visibility_off"
                app:tint="@color/label_cinza"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

        <!-- chips de perfis -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PERFIL DE ACESSO"
            android:textColor="@color/label_cinza"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:id="@+id/chipSocorrista"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_selecionado">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_medical_services"
                    app:tint="@color/vermelho_sos"
                    android:layout_marginEnd="5dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Socorrista" android:textColor="@color/vermelho_sos" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/chipHospital"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_normal">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_local_hospital"
                    app:tint="@color/label_cinza"
                    android:layout_marginEnd="5dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Hospital" android:textColor="@color/label_cinza" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/chipPaciente"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_chip_normal">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/label_cinza"
                    android:layout_marginEnd="5dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Paciente" android:textColor="@color/label_cinza" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnEntrar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ENTRAR"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:background="@drawable/bg_botao_buscar"
            android:layout_marginBottom="14dp"/>

        <TextView
            android:id="@+id/tvEsqueceu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Esqueceu a senha? Recuperar"
            android:textColor="@color/label_cinza"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- linha de divisao q da mo trabalho fzr no xml -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <View android:layout_width="0dp" android:layout_height="0.5dp"
                android:layout_weight="1" android:background="@color/bg_card_elevado"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="  ou continue com  " android:textColor="@color/label_cinza" android:textSize="10sp"/>
            <View android:layout_width="0dp" android:layout_height="0.5dp"
                android:layout_weight="1" android:background="@color/bg_card_elevado"/>
        </LinearLayout>

        <!-- TODO: catar os svgs da apple/google/microsoft dps c o gustavo, deixei em texto por enqnt -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="G  Google"
                android:textColor="@color/label_cinza"
                android:textSize="12sp"
                android:background="@drawable/bg_botao_social"
                android:layout_marginEnd="8dp"/>

            <Button
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🏛  Gov.br"
                android:textColor="@color/label_cinza"
                android:textSize="12sp"
                android:background="@drawable/bg_botao_social"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>