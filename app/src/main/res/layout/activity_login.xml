<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="48dp">

        <!-- Logo + título -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginBottom="12dp">
                <View android:layout_width="44dp" android:layout_height="14dp"
                    android:layout_gravity="center_vertical" android:background="@color/vermelho_sos"/>
                <View android:layout_width="14dp" android:layout_height="44dp"
                    android:layout_gravity="center_horizontal" android:background="@color/vermelho_sos"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOS LEITOS"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acesse sua conta"
                android:textColor="#FF666666"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Campo e-mail -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E-MAIL"
            android:textColor="#FF666666"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✉"
                android:textSize="16sp"
                android:layout_marginEnd="10dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="email@samu.sp.gov.br"
                android:hintTextColor="#FF444444"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:inputType="textEmailAddress"
                android:background="@null"
                android:singleLine="true"/>
        </LinearLayout>

        <!-- Campo senha -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SENHA"
            android:textColor="#FF666666"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:textSize="16sp"
                android:layout_marginEnd="10dp"/>

            <EditText
                android:id="@+id/etSenha"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="••••••••"
                android:hintTextColor="#FF444444"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:inputType="textPassword"
                android:background="@null"
                android:singleLine="true"/>
        </LinearLayout>

        <!-- Seleção de perfil -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PERFIL DE ACESSO"
            android:textColor="#FF666666"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:id="@+id/chipSocorrista"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_selecionado">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🚑" android:textSize="14sp" android:layout_marginEnd="5dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Socorrista" android:textColor="#FFEF5350" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/chipHospital"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_normal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏥" android:textSize="14sp" android:layout_marginEnd="5dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Hospital" android:textColor="#FF666666" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/chipAdmin"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_chip_normal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚙" android:textSize="14sp" android:layout_marginEnd="5dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Admin" android:textColor="#FF666666" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Botão entrar -->
        <Button
            android:id="@+id/btnEntrar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ENTRAR"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:background="@drawable/bg_botao_buscar"
            android:layout_marginBottom="14dp"/>

        <!-- Esqueceu a senha -->
        <TextView
            android:id="@+id/tvEsqueceu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Esqueceu a senha? Recuperar"
            android:textColor="#FF555555"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Divisor -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <View android:layout_width="0dp" android:layout_height="0.5dp"
                android:layout_weight="1" android:background="#FF222222"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="  ou continue com  " android:textColor="#FF444444" android:textSize="10sp"/>
            <View android:layout_width="0dp" android:layout_height="0.5dp"
                android:layout_weight="1" android:background="#FF222222"/>
        </LinearLayout>

        <!-- Botões sociais -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="G  Google"
                android:textColor="#FF888888"
                android:textSize="12sp"
                android:background="@drawable/bg_botao_social"
                android:layout_marginEnd="8dp"/>

            <Button
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="🏛  Gov.br"
                android:textColor="#FF888888"
                android:textSize="12sp"
                android:background="@drawable/bg_botao_social"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
