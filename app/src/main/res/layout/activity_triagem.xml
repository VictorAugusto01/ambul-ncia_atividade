<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1117"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTituloTriagem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Buscar Paciente"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etBuscaRg"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_chip_normal"
        android:drawableStart="@drawable/ic_search"
        android:drawablePadding="12dp"
        android:hint="Digite o RG do Paciente"
        android:inputType="number"
        android:padding="16dp"
        android:textColor="@color/white"
        android:textColorHint="#666666"
        app:layout_constraintTop_toBottomOf="@id/tvTituloTriagem" />

    <Button
        android:id="@+id/btnBuscarRg"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#EF5350"
        android:text="BUSCAR FICHA"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/etBuscaRg" />

    <Button
        android:id="@+id/btnIrParaMapa"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#D32F2F"
        android:text="🗺️ ABRIR MAPA / ROTAS"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnBuscarRg" />

    <LinearLayout
        android:id="@+id/cardFichaPaciente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_chip_normal"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btnIrParaMapa">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRONTUÁRIO ENCONTRADO"
            android:textColor="#64B5F6"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNomePacienteTriagem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Paciente: -"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSangueTriagem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Sangue: -"
            android:textColor="#AAAAAA"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/alertaAlergia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#3E1A1A"
            android:padding="12dp"
            android:text="⚠️ ALERTA: POSSÍVEL CHOQUE ANAFILÁTICO"
            android:textColor="#EF5350"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvAlergiasTriagem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Alergias: -"
            android:textColor="#AAAAAA"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/containerRecentesMock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/cardFichaPaciente">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PACIENTES RECENTES (CACHED)"
            android:textColor="#666666"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_chip_normal"
            android:padding="16dp"
            android:text="👤 Carlos M. Silva\nRG: 12.345.678-9 | Há 2 horas"
            android:textColor="#AAAAAA" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_chip_normal"
            android:padding="16dp"
            android:text="👤 Amanda T. Souza\nRG: 98.765.432-1 | Ontem"
            android:textColor="#AAAAAA" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>